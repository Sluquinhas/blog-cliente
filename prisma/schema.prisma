generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Artigo {
  id            Int      @id @default(autoincrement())
  titulo        String
  slug          String   @unique
  categoria     String
  resumo        String
  conteudo      String
  autor         String
  data          String
  tempoLeitura  String
  status        String   @default("Rascunho")
  imagemCapa    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}