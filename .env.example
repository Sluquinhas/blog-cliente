# ---------------------------------------------------------------------------
# Variáveis de ambiente do blog "Economista Raimundo Padilha"
# Copie para `.env` (desenvolvimento) ou configure no ambiente do servidor.
# NUNCA versione o arquivo `.env` real (já está no .gitignore).
# ---------------------------------------------------------------------------

# Banco SQLite via Prisma (adapter better-sqlite3).
# Desenvolvimento:
#   DATABASE_URL="file:./dev.db"
# Produção (disco persistente, FORA da pasta de releases):
#   DATABASE_URL="file:/var/lib/padilha-blog/prod.db"
DATABASE_URL="file:./dev.db"

# Senha única do painel /admin. Use uma senha forte e secreta.
ADMIN_PASSWORD="defina-uma-senha-forte"

# Segredo para assinar o cookie de sessão (HMAC-SHA256).
# Gere com: openssl rand -base64 32
SESSION_SECRET="gere-um-segredo-com-openssl-rand-base64-32"

# URL pública canônica do site (sem barra no final).
# Desenvolvimento: http://localhost:3000
# Produção:        https://padilha.com.br
NEXT_PUBLIC_SITE_URL="https://padilha.com.br"

# Ambiente (Next define automaticamente, mas pode ser explicitado no servidor).
# NODE_ENV="production"
